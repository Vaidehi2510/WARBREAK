{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "api/index.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "includeFiles": "backend/**",
      "maxDuration": 60
    }
  }
}
